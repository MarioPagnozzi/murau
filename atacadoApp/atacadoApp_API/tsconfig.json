{
   "compilerOptions": {
      "lib": [
         "es5",
         "es6",
         "ES2020"
      ],
      "target": "ES2020",
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "./build",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "sourceMap": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "resolveJsonModule": true,
      "paths": {
         "*": [
            "./node_modules/*"
         ]
      }
      
   },
   "include": [
      "src/**/*",
      "./ormconfig.json",
      "./ormconfig-prod.json",
      "./package.json",
      "./pkgstart.json"
   ]
}