{
    "apps": [{
        "name": "apimurau.mapxsolucoes.com.br",
        "script": "src/index.ts",
        "watch": ["atacadoApp_API", "src"],
        "env": {
            "NODE_ENV": "development",
            "TARGET": "https://apimurau.mapxsolucoes.com.br:9443",
            "KEY": "C:/Program Files/OpenSSL-Win64/bin/certificate.key",
            "CERT": "C:/Program Files/OpenSSL-Win64/bin/certificate.crt",
            "CA": "",
            "DHPARAM": ""
        },
        "env_production": {
            "NODE_ENV": "production",
            "TARGET": "https://api.murau.com.br:9443",
            "KEY": "usr/local/directadmin/data/users/murau/domains/api.murau.com.br.key",
            "CERT": "usr/local/directadmin/data/users/murau/domains/api.murau.com.br.cert",
            "CA": "usr/local/directadmin/data/users/murau/domains/api.murau.com.br.cacert",
            "DHPARAM": "usr/local/directadmin/data/users/murau/domains/api.murau.com.br.cert.combined"
        }
    }],
    "postinstall": "$(yum bin)/pm2 install typecsript"
}